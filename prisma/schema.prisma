generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Legacy table for migration
model Word {
  id              BigInt    @id @default(autoincrement())
  bikol           String?   @unique(map: "unique_bikol_word")
  english         String?
  pos             String?
  category        String?
  dialect         String?
  example_bikol   String?
  example_english String?
  pronunciation   String?
  synonyms        String?
  tagalog         String?
  confidence      Float?    @default(1.0)
  source_url      String?
  audio_url       String?
  etymology       String?
  frequency_rank  Int?
  created_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@map("words")
}

enum FocusClass {
  ON_CLASS
  I_CLASS
  AN_CLASS
  MAG_INTRANSITIVE
  UNKNOWN
}

// Normalized Mintz Models
model Root {
  id             String       @id @default(cuid())
  bikol          String
  pos            String?
  category       String?
  pronunciation  String?
  etymology      String?
  frequency_rank Int?
  audio_url      String?
  focusClass     FocusClass   @default(UNKNOWN)
  isTransitive   Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  definitions    Definition[]

  @@map("roots")
}

model Definition {
  id               String            @id @default(cuid())
  rootId           String
  root             Root              @relation(fields: [rootId], references: [id], onDelete: Cascade)
  english          String?
  dialect          String?
  synonyms         String?
  tagalog          String?
  aiConfidence     Float?            @default(1.0)
  source_url       String?
  source           String?           @default("unknown")
  affixPair        String?           @default("UNKNOWN")
  focusType        String?           @default("UNKNOWN")
  series           String?           @default("REGULAR")
  isVerified       Boolean?          @default(false)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  conjugations     Conjugation[]
  exampleSentences ExampleSentence[]

  @@map("definitions")
}

model Conjugation {
  id           String     @id @default(cuid())
  definitionId String
  definition   Definition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  tense        String?
  focus        String?
  form         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([definitionId, tense, focus])
  @@map("conjugations")
}

model ExampleSentence {
  id           String     @id @default(cuid())
  definitionId String
  definition   Definition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  bikol        String?
  english      String?
  source       String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("example_sentences")
}

// Existing tables preserved
model UserSubmission {
  id              Int       @id @default(autoincrement())
  word            String
  definition      String
  pos             String?
  dialect         String?
  pronunciation   String?
  example_bikol   String?
  example_english String?
  tagalog         String?
  source          String?
  status          String?   @default("pending")
  target_table    String?   @default("legacy")
  admin_notes     String?
  original_id     String?
  original_type   String?
  created_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@map("user_submissions")
}

model UserFlashcard {
  id                Int       @id @default(autoincrement())
  user_id           String?   @db.Uuid
  word_bikol        String
  proficiency_score Int?      @default(0)
  next_review       DateTime? @db.Timestamptz(6)
  created_at        DateTime? @default(now()) @db.Timestamptz(6)

  @@map("user_flashcards")
}

model DialogueScenario {
  id          String   @id @default(cuid())
  title       String
  description String
  goal        String
  difficulty  String   @default("beginner")
  visualCue   String
  vocabulary  String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("dialogue_scenarios")
}
