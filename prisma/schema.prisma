generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Word {
  bikol           String   @id
  english         String
  pos             String?
  category        String?
  dialect         String?
  example_bikol   String?
  example_english String?
  pronunciation   String?
  synonyms        String?
  tagalog         String?
  confidence      Float    @default(1.0)
  source_url      String?
  frequency_rank  Int?

  @@map("words")
}

model UserSubmission {
  id         Int       @id @default(autoincrement())
  word       String
  definition String
  dialect    String?
  status     String?   @default("pending")
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@map("user_submissions")
}

model UserFlashcard {
  id                Int       @id @default(autoincrement())
  user_id           String?   @db.Uuid
  word_bikol        String
  proficiency_score Int?      @default(0)
  next_review       DateTime? @db.Timestamptz(6)
  created_at        DateTime? @default(now()) @db.Timestamptz(6)

  @@map("user_flashcards")
}
