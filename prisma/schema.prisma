generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Legacy table for migration
model Word {
  id              BigInt    @id @default(autoincrement())
  bikol           String?   @unique(map: "unique_bikol_word")
  english         String?
  pos             String?
  category        String?
  dialect         String?
  example_bikol   String?
  example_english String?
  pronunciation   String?
  synonyms        String?
  tagalog         String?
  confidence      Float?    @default(1.0)
  source_url      String?
  audio_url       String?
  etymology       String?
  frequency_rank  Int?
  created_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@map("words")
}

enum FocusClass {
  ON_CLASS
  I_CLASS
  AN_CLASS
  MAG_INTRANSITIVE
  UNKNOWN
}

enum BadgeCategory {
  CONTRIBUTION
  LEARNING
  STREAK
  MILESTONE
}

// Normalized Mintz Models
model Root {
  id             String       @id @default(cuid())
  bikol          String
  pos            String?
  category       String?
  pronunciation  String?
  etymology      String?
  frequency_rank Int?
  audio_url      String?
  focusClass     FocusClass   @default(UNKNOWN)
  isTransitive   Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  definitions    Definition[]

  @@map("roots")
}

model Definition {
  id               String            @id @default(cuid())
  rootId           String
  root             Root              @relation(fields: [rootId], references: [id], onDelete: Cascade)
  english          String?
  dialect          String?
  synonyms         String?
  tagalog          String?
  aiConfidence     Float?            @default(1.0)
  source_url       String?
  source           String?           @default("unknown")
  affixPair        String?           @default("UNKNOWN")
  focusType        String?           @default("UNKNOWN")
  series           String?           @default("REGULAR")
  isVerified       Boolean?          @default(false)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  conjugations     Conjugation[]
  exampleSentences ExampleSentence[]

  @@map("definitions")
}

model Conjugation {
  id           String     @id @default(cuid())
  definitionId String
  definition   Definition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  tense        String?
  focus        String?
  form         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([definitionId, tense, focus])
  @@map("conjugations")
}

model ExampleSentence {
  id           String     @id @default(cuid())
  definitionId String
  definition   Definition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  bikol        String?
  english      String?
  source       String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("example_sentences")
}

// Existing tables preserved
model UserSubmission {
  id              Int       @id @default(autoincrement())
  word            String
  definition      String
  pos             String?
  dialect         String?
  pronunciation   String?
  example_bikol   String?
  example_english String?
  tagalog         String?
  source          String?
  status          String?   @default("pending")
  target_table    String?   @default("legacy")
  admin_notes     String?
  original_id     String?
  original_type   String?
  userId          String?   @db.Uuid
  pointsAwarded   Int?      @default(0)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime? @updatedAt @db.Timestamptz(6)

  @@index([userId, status])
  @@index([status, created_at])
  @@map("user_submissions")
}

model UserFlashcard {
  id                Int       @id @default(autoincrement())
  user_id           String?   @db.Uuid
  profile           Profile?  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  word_bikol        String
  proficiency_score Int?      @default(0)
  next_review       DateTime? @db.Timestamptz(6)
  created_at        DateTime? @default(now()) @db.Timestamptz(6)

  @@map("user_flashcards")
}

model DialogueScenario {
  id          String   @id @default(cuid())
  title       String
  description String
  goal        String
  difficulty  String   @default("beginner")
  visualCue   String
  vocabulary  String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("dialogue_scenarios")
}

// ─── Gamification Models (Phase 1) ────────────────────────────────────────

model Profile {
  id            String    @id @db.Uuid
  username      String?   @unique @db.VarChar(30)
  displayName   String?   @db.VarChar(100)
  avatarUrl     String?   @db.VarChar(500)
  isAnonymous   Boolean   @default(false)

  totalXp       Int       @default(0)
  scholarXp     Int       @default(0)
  contributorXp Int       @default(0)

  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime? @db.Timestamptz(6)

  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)

  contributions Contribution[]
  badges        UserBadge[]
  activities    ActivityLog[]
  quizAttempts  QuizAttempt[]
  drillSessions DrillSession[]
  flashcards    UserFlashcard[]

  @@index([lastActivityDate])
  @@map("profiles")
}

model Contribution {
  id          String   @id @default(cuid())
  userId      String   @db.Uuid
  profile     Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String   @db.VarChar(30)
  points      Int
  referenceId String?
  metadata    Json?

  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("contributions")
}

model Badge {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String
  icon        String
  category    BadgeCategory
  tier        Int           @default(1)

  users       UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String   @db.Uuid
  badgeId  String
  earnedAt DateTime @default(now()) @db.Timestamptz(6)
  seen     Boolean  @default(false)

  profile  Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([badgeId])
  @@map("user_badges")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  profile   Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   @db.VarChar(30)
  metadata  Json?
  xpEarned  Int      @default(0)

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId, createdAt])
  @@map("activity_log")
}

model QuizAttempt {
  id             String   @id @default(cuid())
  userId         String   @db.Uuid
  profile        Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  totalQuestions Int
  correctAnswers Int
  score          Float
  duration       Int?

  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId, createdAt])
  @@map("quiz_attempts")
}

model DrillSession {
  id            String   @id @default(cuid())
  userId        String   @db.Uuid
  profile       Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  phase         Int
  totalRounds   Int
  correctRounds Int
  score         Float

  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId, createdAt])
  @@map("drill_sessions")
}
