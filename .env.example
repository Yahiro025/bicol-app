# ─────────────────────────────────────────────────────────────────────
# BIKOL Dictionary — Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────

# Database (PostgreSQL on Supabase)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres"

# Supabase (legacy — used by Python/scripts data pipeline)
SUPABASE_URL="https://[YOUR-PROJECT].supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"

# Groq AI — quiz generation, dialogue processing, linguistic audit
GROQ_API_KEY="gsk_your-groq-api-key"

# Admin Authentication — HMAC-based (no third-party auth)
# ADMIN_PASSWORD must be >= 12 characters
ADMIN_PASSWORD="replace-with-a-long-admin-password"
# ADMIN_SESSION_SECRET must be >= 32 characters
ADMIN_SESSION_SECRET="replace-with-at-least-32-random-characters"

# Deployment
NEXT_PUBLIC_SITE_URL="https://bikoldictionary.app"

# Build — set to "mobile" for Capacitor static export
# NEXT_PUBLIC_PLATFORM="mobile"
